    length: int = Query(12, ge=4, le=32),
    use_uppercase: bool = Query(True),
    use_digits: bool = Query(True),
    use_symbols: bool = Query(True)
):
    """API endpoint для генерации пароля"""
    password = generate_password(length, use_digits, use_symbols, use_uppercase)
    return {"password": password}

