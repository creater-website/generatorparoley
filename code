                const icon = toast.querySelector('i');
                toastMessage.textContent = message;
                
                if (type === "success") {
                    icon.className = "fas fa-check-circle";
                    icon.style.color = "#10b981";
                } else {
                    icon.className = "fas fa-exclamation-triangle";
                    icon.style.color = "#f87171";
                }
                
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                }, 2000);
            }
            
            // Обработчики событий
            lengthSlider.addEventListener('input', updateLengthValue);
            generateBtn.addEventListener('click', generatePassword);
            copyBtn.addEventListener('click', copyPassword);
            
            // Авто-генерация при изменении настроек
            uppercaseCheck.addEventListener('change', generatePassword);
            digitsCheck.addEventListener('change', generatePassword);
            symbolsCheck.addEventListener('change', generatePassword);
            lengthSlider.addEventListener('change', generatePassword);
            
            // Инициализация
            updateLengthValue();
            generatePassword();
        </script>
